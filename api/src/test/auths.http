### LOGIN WITH VALID USER
# EXPECTED: 200
POST {{baseUrl}}/auths/login
Content-Type: application/json

{
  "email":"player1@mail.com",
  "password":"Password1!"
}

### LOGIN SECOND USER
# EXPECTED: 200
POST {{baseUrl}}/auths/login
Content-Type: application/json

{
  "email":"player2@mail.com",
  "password":"Password1!"
}

### LOGIN WITH WRONG PASSWORD
# EXPECTED: 401
POST {{baseUrl}}/auths/login
Content-Type: application/json

{
  "email":"player1@mail.com",
  "password":"WrongPassword1!"
}

### LOGIN UNKNOWN USER
# EXPECTED: 401
POST {{baseUrl}}/auths/login
Content-Type: application/json

{
  "email":"unknown@mail.com",
  "password":"Password1!"
}

