@baseUrl = http://localhost:3000

### REGISTER A NEW MEMBER
# EXPECTED: 200
POST {{baseUrl}}/auths/register
Content-Type: application/json

{
  "email":"player1@mail.com",
  "password":"Password1!",
  "tag":"Vector",
  "specialityId":1,
  "profileImageId":1
}

### REGISTER A SECOND MEMBER
# EXPECTED: 200
POST {{baseUrl}}/auths/register
Content-Type: application/json

{
  "email":"player2@mail.com",
  "password":"Password1!",
  "tag":"Rogue",
  "specialityId":2,
  "profileImageId":1
}

### REGISTER WITH EXISTING EMAIL
# EXPECTED: 409
POST {{baseUrl}}/auths/register
Content-Type: application/json

{
  "email":"player1@mail.com",
  "password":"Password1!",
  "tag":"Duplicate",
  "specialityId":1,
  "profileImageId":1
}

### REGISTER WITHOUT EMAIL
# EXPECTED: 400
POST {{baseUrl}}/auths/register
Content-Type: application/json

{
  "password":"Password1!",
  "tag":"NoEmail",
  "specialityId":1,
  "profileImageId":1
}

### REGISTER WITHOUT PASSWORD
# EXPECTED: 400
POST {{baseUrl}}/auths/register
Content-Type: application/json

{
  "email":"player3@mail.com",
  "tag":"NoPassword",
  "specialityId":1,
  "profileImageId":1
}

### REGISTER WITHOUT TAG
# EXPECTED: 200 (depends on backend rules)
POST {{baseUrl}}/auths/register
Content-Type: application/json

{
  "email":"player4@mail.com",
  "password":"Password1!",
  "specialityId":1,
  "profileImageId":1
}

### REGISTER WITH EMPTY BODY
# EXPECTED: 400
POST {{baseUrl}}/auths/register
Content-Type: application/json

{
}

### REGISTER WITH EMPTY REQUEST
# EXPECTED: 400
POST {{baseUrl}}/auths/register
Content-Type: application/json


### REGISTER WITH WEAK PASSWORD (TOO SHORT)
# EXPECTED: 400
POST {{baseUrl}}/auths/register
Content-Type: application/json

{
  "email":"weak1@mail.com",
  "password":"Pass1!",
  "tag":"Weak",
  "specialityId":1,
  "profileImageId":1
}

