@baseUrl = http://localhost:3000

### Register a new member
POST {{baseUrl}}/auths/register
Content-Type: application/json

{
  "email":"player1@mail.com",
  "password":"123",
  "tag":"Vector",
  "specialityId":1,
  "profileImageId":1
}

### Register a second member
POST {{baseUrl}}/auths/register
Content-Type: application/json

{
  "email":"player2@mail.com",
  "password":"123",
  "tag":"Rogue",
  "specialityId":2,
  "profileImageId":1
}

### Try to register with an existing email
POST {{baseUrl}}/auths/register
Content-Type: application/json

{
  "email":"player1@mail.com",
  "password":"123",
  "tag":"Duplicate",
  "specialityId":1,
  "profileImageId":1
}

### Try to register without email
POST {{baseUrl}}/auths/register
Content-Type: application/json

{
  "password":"123",
  "tag":"NoEmail",
  "specialityId":1,
  "profileImageId":1
}

### Try to register without password
POST {{baseUrl}}/auths/register
Content-Type: application/json

{
  "email":"player3@mail.com",
  "tag":"NoPassword",
  "specialityId":1,
  "profileImageId":1
}

### Try to register without tag
POST {{baseUrl}}/auths/register
Content-Type: application/json

{
  "email":"player4@mail.com",
  "password":"123",
  "specialityId":1,
  "profileImageId":1
}

### Try to register with empty body
POST {{baseUrl}}/auths/register
Content-Type: application/json

{
}

### Try to register with empty request
POST {{baseUrl}}/auths/register
Content-Type: application/json